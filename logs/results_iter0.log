    axes[0, 1].set_xlabel('Multipole ell')
    axes[0, 1].set_ylabel('D_ell TE [K^2]')
    axes[0, 1].set_yscale('symlog', linthresh=1e-10)
    axes[1, 0].set_title('EE Spectrum')
