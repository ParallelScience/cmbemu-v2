        axes[0, 1].plot(ell_tt_te_ee[2:], train_combined['te'][i, 2:] * factor_tt_te_ee[2:], alpha=0.7)
        axes[1, 0].plot(ell_tt_te_ee[2:], train_combined['ee'][i, 2:] * factor_tt_te_ee[2:], alpha=0.7)
